{
  "name": "lorerelay",
  "displayName": "LoreRelay",
  "description": "Local-first AI Game Master UI. Works with any AI assistant.",
  "version": "1.6.3",
  "publisher": "Miya",
  "author": "Miya",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GGF1sh/LoreRelay.git"
  },
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "keywords": [
    "ai",
    "game-master",
    "roleplay",
    "trpg",
    "visual-novel",
    "sillytavern",
    "grok",
    "llm"
  ],
  "activationEvents": [
    "onCommand:textadventure.openGame",
    "onCommand:textadventure.listImageModels",
    "onCommand:textadventure.loadScenario",
    "onCommand:textadventure.importStCharacter",
    "onCommand:textadventure.importStLorebook",
    "onCommand:textadventure.exportScenario",
    "onCommand:textadventure.validateScenario",
    "onCommand:textadventure.setOpenRouterApiKey",
    "onCommand:textadventure.clearOpenRouterApiKey",
    "onCommand:textadventure.checkForUpdates",
    "onCommand:textadventure.startRemotePlay",
    "onCommand:textadventure.stopRemotePlay",
    "onCommand:textadventure.rotateRemotePlayToken",
    "onCommand:textadventure.generateWorldForge"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "textadventure.openGame",
        "title": "%command.openGame%"
      },
      {
        "command": "textadventure.listImageModels",
        "title": "%command.listImageModels%"
      },
      {
        "command": "textadventure.loadScenario",
        "title": "%command.loadScenario%"
      },
      {
        "command": "textadventure.importStCharacter",
        "title": "%command.importStCharacter%"
      },
      {
        "command": "textadventure.importStLorebook",
        "title": "%command.importStLorebook%"
      },
      {
        "command": "textadventure.exportScenario",
        "title": "%command.exportScenario%"
      },
      {
        "command": "textadventure.validateScenario",
        "title": "%command.validateScenario%"
      },
      {
        "command": "textadventure.setOpenRouterApiKey",
        "title": "%command.setOpenRouterApiKey%"
      },
      {
        "command": "textadventure.clearOpenRouterApiKey",
        "title": "%command.clearOpenRouterApiKey%"
      },
      {
        "command": "textadventure.checkForUpdates",
        "title": "%command.checkForUpdates%"
      },
      {
        "command": "textadventure.startRemotePlay",
        "title": "%command.startRemotePlay%"
      },
      {
        "command": "textadventure.stopRemotePlay",
        "title": "%command.stopRemotePlay%"
      },
      {
        "command": "textadventure.rotateRemotePlayToken",
        "title": "%command.rotateRemotePlayToken%"
      },
      {
        "command": "textadventure.generateWorldForge",
        "title": "%command.generateWorldForge%"
      }
    ],
    "configuration": {
      "title": "LoreRelay",
      "properties": {
        "textAdventure.locale": {
          "type": "string",
          "enum": [
            "ja",
            "en",
            "zh-CN",
            "zh-TW"
          ],
          "enumDescriptions": [
            "日本語",
            "English",
            "简体中文 (Simplified Chinese)",
            "繁體中文 (Traditional Chinese / Taiwan)"
          ],
          "default": "en",
          "description": "%config.textAdventure.locale.description%"
        },
        "textAdventure.skillPath": {
          "type": "string",
          "default": "C:\\AI\\TextAdventureGMSkill\\scripts\\comfyui_generate.py",
          "description": "%config.textAdventure.skillPath.description%"
        },
        "textAdventure.imageGen.backend": {
          "type": "string",
          "enum": [
            "comfyui",
            "stabilitymatrix",
            "custom"
          ],
          "enumDescriptions": [
            "Standalone ComfyUI (default 127.0.0.1:8188)",
            "ComfyUI bundled in Stability Matrix",
            "Any ComfyUI-compatible server (set the URL manually)"
          ],
          "default": "comfyui",
          "description": "%config.textAdventure.imageGen.backend.description%"
        },
        "textAdventure.imageGen.comfyuiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8188",
          "description": "%config.textAdventure.imageGen.comfyuiUrl.description%"
        },
        "textAdventure.imageGen.checkpoint": {
          "type": "string",
          "default": "",
          "description": "%config.textAdventure.imageGen.checkpoint.description%"
        },
        "textAdventure.imageGen.workflowPath": {
          "type": "string",
          "default": "",
          "description": "%config.textAdventure.imageGen.workflowPath.description%"
        },
        "textAdventure.imageGen.steps": {
          "type": "number",
          "default": 0,
          "description": "%config.textAdventure.imageGen.steps.description%"
        },
        "textAdventure.imageGen.cfg": {
          "type": "number",
          "default": 0,
          "description": "%config.textAdventure.imageGen.cfg.description%"
        },
        "textAdventure.imageGen.width": {
          "type": "number",
          "default": 0,
          "description": "%config.textAdventure.imageGen.width.description%"
        },
        "textAdventure.imageGen.height": {
          "type": "number",
          "default": 0,
          "description": "%config.textAdventure.imageGen.height.description%"
        },
        "textAdventure.imageGen.autoOnLocationChange": {
          "type": "boolean",
          "default": false,
          "description": "%config.textAdventure.imageGen.autoOnLocationChange.description%"
        },
        "textAdventure.imageGen.includeFactionInPrompt": {
          "type": "boolean",
          "default": true,
          "description": "%config.textAdventure.imageGen.includeFactionInPrompt.description%"
        },
        "textAdventure.imageGen.includeDangerInPrompt": {
          "type": "boolean",
          "default": true,
          "description": "%config.textAdventure.imageGen.includeDangerInPrompt.description%"
        },
        "textAdventure.vlm.provider": {
          "type": "string",
          "enum": [
            "disabled",
            "ollama",
            "openrouter"
          ],
          "default": "disabled",
          "description": "%config.textAdventure.vlm.provider.description%"
        },
        "textAdventure.vlm.model": {
          "type": "string",
          "default": "llava",
          "description": "%config.textAdventure.vlm.model.description%"
        },
        "textAdventure.vlm.endpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "%config.textAdventure.vlm.endpoint.description%"
        },
        "textAdventure.bgm.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.textAdventure.bgm.enabled.description%"
        },
        "textAdventure.bgm.manifestPath": {
          "type": "string",
          "default": "",
          "description": "%config.textAdventure.bgm.manifestPath.description%"
        },
        "textAdventure.bgm.volume": {
          "type": "number",
          "default": 50,
          "description": "%config.textAdventure.bgm.volume.description%"
        },
        "textAdventure.sfx.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.textAdventure.sfx.enabled.description%"
        },
        "textAdventure.sfx.manifestPath": {
          "type": "string",
          "default": "",
          "description": "%config.textAdventure.sfx.manifestPath.description%"
        },
        "textAdventure.sfx.volume": {
          "type": "number",
          "default": 70,
          "description": "%config.textAdventure.sfx.volume.description%"
        },
        "textAdventure.mediaAgent.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.textAdventure.mediaAgent.enabled.description%"
        },
        "textAdventure.mediaAgent.autoImage": {
          "type": "boolean",
          "default": true,
          "description": "%config.textAdventure.mediaAgent.autoImage.description%"
        },
        "textAdventure.mediaAgent.maxImageQueue": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "%config.textAdventure.mediaAgent.maxImageQueue.description%"
        },
        "textAdventure.remotePlay.port": {
          "type": "number",
          "default": 9473,
          "minimum": 1024,
          "maximum": 65535,
          "description": "%config.textAdventure.remotePlay.port.description%"
        },
        "textAdventure.remotePlay.bindAddress": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "%config.textAdventure.remotePlay.bindAddress.description%"
        },
        "textAdventure.remotePlay.maxClients": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 32,
          "description": "%config.textAdventure.remotePlay.maxClients.description%"
        },
        "textAdventure.remotePlay.inputCooldownMs": {
          "type": "number",
          "default": 1500,
          "minimum": 500,
          "maximum": 10000,
          "description": "%config.textAdventure.remotePlay.inputCooldownMs.description%"
        },
        "textAdventure.remotePlay.defaultRole": {
          "type": "string",
          "enum": [
            "player",
            "spectator"
          ],
          "default": "player",
          "description": "%config.textAdventure.remotePlay.defaultRole.description%"
        },
        "textAdventure.remotePlay.mediaUrlTtlSec": {
          "type": "number",
          "default": 300,
          "minimum": 60,
          "maximum": 3600,
          "description": "%config.textAdventure.remotePlay.mediaUrlTtlSec.description%"
        },
        "textAdventure.workspaceFolder": {
          "type": "string",
          "default": "",
          "description": "%config.textAdventure.workspaceFolder.description%"
        },
        "textAdventure.gitAutoCommitInterval": {
          "type": "number",
          "default": 1,
          "description": "%config.textAdventure.gitAutoCommitInterval.description%"
        },
        "textAdventure.gmBridge.provider": {
          "type": "string",
          "enum": [
            "grok",
            "clipboard",
            "command",
            "ollama",
            "koboldcpp",
            "openrouter"
          ],
          "default": "grok",
          "enumDescriptions": [
            "Grok Build headless (grok -p)",
            "Copy player input to clipboard only",
            "Custom executable via gmBridge.command",
            "Local Ollama via ollama_gm.py (ollama serve required)",
            "Local KoboldCPP via koboldcpp_gm.py (koboldcpp.exe API required)",
            "OpenRouter via openrouter_gm.py (Cloud-based API, requires API Key)"
          ],
          "description": "%config.textAdventure.gmBridge.provider.description%"
        },
        "textAdventure.gmBridge.python": {
          "type": "string",
          "default": "python",
          "description": "%config.textAdventure.gmBridge.python.description%"
        },
        "textAdventure.gmBridge.scriptPath": {
          "type": "string",
          "default": "",
          "description": "%config.textAdventure.gmBridge.scriptPath.description%"
        },
        "textAdventure.gmBridge.ollama.url": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "%config.textAdventure.gmBridge.ollama.url.description%"
        },
        "textAdventure.gmBridge.ollama.model": {
          "type": "string",
          "default": "llama3.2",
          "description": "%config.textAdventure.gmBridge.ollama.model.description%"
        },
        "textAdventure.gmBridge.koboldcpp.url": {
          "type": "string",
          "default": "http://127.0.0.1:5001",
          "description": "%config.textAdventure.gmBridge.koboldcpp.url.description%"
        },
        "textAdventure.gmBridge.openRouter.apiKey": {
          "type": "string",
          "default": "",
          "description": "%config.textAdventure.gmBridge.openRouter.apiKey.description%"
        },
        "textAdventure.gmBridge.openRouter.model": {
          "type": "string",
          "default": "anthropic/claude-3.5-sonnet",
          "description": "%config.textAdventure.gmBridge.openRouter.model.description%"
        },
        "textAdventure.gmBridge.command": {
          "type": "string",
          "default": "",
          "description": "%config.textAdventure.gmBridge.command.description%"
        },
        "textAdventure.gmBridge.commandArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--prompt-file",
            "{actionFile}",
            "--cwd",
            "{cwd}",
            "--always-approve"
          ],
          "description": "%config.textAdventure.gmBridge.commandArgs.description%"
        },
        "textAdventure.grokBridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.textAdventure.grokBridge.enabled.description%"
        },
        "textAdventure.grokBridge.command": {
          "type": "string",
          "default": "grok",
          "description": "%config.textAdventure.grokBridge.command.description%"
        },
        "textAdventure.grokBridge.autoApprove": {
          "type": "boolean",
          "default": false,
          "description": "%config.textAdventure.grokBridge.autoApprove.description%"
        },
        "textAdventure.grokBridge.fallbackToClipboard": {
          "type": "boolean",
          "default": true,
          "description": "%config.textAdventure.grokBridge.fallbackToClipboard.description%"
        },
        "textAdventure.archive.autoPrompt": {
          "type": "boolean",
          "default": true,
          "description": "%config.textAdventure.archive.autoPrompt.description%"
        },
        "textAdventure.archive.thresholdSmallContext": {
          "type": "number",
          "default": 30,
          "description": "%config.textAdventure.archive.thresholdSmallContext.description%"
        },
        "textAdventure.archive.thresholdLargeContext": {
          "type": "number",
          "default": 80,
          "description": "%config.textAdventure.archive.thresholdLargeContext.description%"
        },
        "textAdventure.archive.remindEvery": {
          "type": "number",
          "default": 15,
          "description": "%config.textAdventure.archive.remindEvery.description%"
        },
        "textAdventure.worldForge.defaultRegionCount": {
          "type": "number",
          "default": 5,
          "minimum": 3,
          "maximum": 12,
          "description": "%config.textAdventure.worldForge.defaultRegionCount.description%"
        },
        "textAdventure.worldForge.defaultFactionCount": {
          "type": "number",
          "default": 3,
          "minimum": 2,
          "maximum": 6,
          "description": "%config.textAdventure.worldForge.defaultFactionCount.description%"
        },
        "textAdventure.worldForge.defaultNpcCount": {
          "type": "number",
          "default": 6,
          "minimum": 2,
          "maximum": 20,
          "description": "%config.textAdventure.worldForge.defaultNpcCount.description%"
        },
        "textAdventure.worldForge.llmEnrich": {
          "type": "boolean",
          "default": false,
          "description": "%config.textAdventure.worldForge.llmEnrich.description%"
        },
        "textAdventure.memory.backend": {
          "type": "string",
          "enum": [
            "auto",
            "tfidf",
            "chromadb"
          ],
          "enumDescriptions": [
            "Use ChromaDB if pip install chromadb succeeded, else TF-IDF",
            "Always use lightweight TF-IDF (no extra deps)",
            "Require ChromaDB embedding search (falls back if not installed)"
          ],
          "default": "auto",
          "description": "%config.textAdventure.memory.backend.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build:webview": "node scripts/build-webview.js",
    "compile": "npm run build:webview && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node scripts/validate.js && node scripts/test_media_paths.js && node scripts/test_lorebook_save.js && node scripts/test_scenario_director.js && node scripts/test_party_director.js && node scripts/test_sample_scenarios.js && node scripts/test_memory_bank.js && node scripts/test_migrate_game_state.js && node scripts/test_remote_media_signature_core.js && node scripts/test_remote_play_server.js && node scripts/test_ws_functionality.js && node scripts/test_validate_game_state.js && node scripts/test_dice_roller.js && node scripts/test_gm_prompt_builder_core.js && node scripts/test_webview_handlers_core.js && node scripts/test_webview_bundle.js && node scripts/test_world_forge.js && node scripts/test_world_state.js && node scripts/test_emergent_simulator.js && node scripts/test_npc_registry.js && node scripts/test_world_map_generator.js && node scripts/test_cartography_layout_core.js && node scripts/test_world_forge_generator.js && node scripts/test_location_image_builder.js && node scripts/test_world_event_log.js && node scripts/test_npc_bridge.js && node scripts/test_visual_memory.js && node scripts/test_vlm_queue_core.js && node scripts/test_tavern_card_importer.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "mermaid": "^11.16.0",
    "ws": "^8.21.0"
  }
}
