  "mode": "quick",
  "modes": ["quick", "full"],
  "seed": "noai-merchant-300-seed",
  "policyId": "merchant_balanced",
  "workspace": { "source": "fixture", "fixturePath": "scripts/noai_soak_scenarios/fixtures/merchant_three_market" },
